# PAI Environment Configuration
# ============================================================================
# Copy this file to ~/.claude/.env and fill in your values.
# NEVER commit the real .env to git — it's in .gitignore.
# Store actual values in your password manager.
# ============================================================================

# ============================================================================
# VOICE SERVER CONFIGURATION
# ============================================================================
PORT=8888

# ============================================================================
# CORE API KEYS
# ============================================================================

# OpenAI API Key (for GPT integration)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API Key (for Claude integration)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ============================================================================
# VOICE SYSTEM
# ============================================================================

# ElevenLabs API Configuration
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ============================================================================
# RESEARCH AGENTS - API Keys (Optional)
# ============================================================================

# Perplexity API (perplexity-researcher agent)
# Get from: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=

# Google Gemini API (gemini-researcher agent)
# Get from: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# ============================================================================
# AI IMAGE/VIDEO GENERATION (Optional)
# ============================================================================

# Replicate API (for Flux, Sora, etc.)
# Get from: https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ============================================================================
# TASK MANAGEMENT
# ============================================================================

# Todoist API Key (if using Todoist skill)
TODOIST_API_KEY=

# RescueTime API Key (for screen time tracking in reviews)
# Get from: https://www.rescuetime.com/anapi/manage
RESCUE_TIME_API_KEY=

# ============================================================================
# ADDITIONAL SERVICES (Optional)
# ============================================================================

# BrightData (for web scraping with CAPTCHA bypass)
BRIGHTDATA_API_KEY=

# ============================================================================
# DIGITAL ASSISTANT CUSTOMIZATION
# ============================================================================

DA="PAI"
DA_COLOR="purple"

# ============================================================================
# PAI PATHS
# ============================================================================

PAI_DIR="/home/YOUR_USER/.claude"
PAI_HOME="/home/YOUR_USER"
